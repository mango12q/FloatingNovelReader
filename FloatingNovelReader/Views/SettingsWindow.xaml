<Window x:Class="FloatingNovelReader.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:FloatingNovelReader.Controls"
        Title="设置"
        Width="600" Height="500"
        WindowStartupLocation="CenterOwner"
        Background="White">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <!-- 显示设置 -->
            <TabItem Header="显示">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock Text="字体族" Margin="0,8,0,4"/>
                        <ComboBox x:Name="FontFamilyCombo" SelectedItem="{Binding Current.Display.FontFamily}"
                                  ItemsSource="{Binding FontFamilies}"/>

                        <TextBlock Text="字体大小" Margin="0,8,0,4"/>
                        <Slider Minimum="12" Maximum="48" TickFrequency="1"
                                Value="{Binding Current.Display.FontSize}" IsSnapToTickEnabled="True"/>
                        <TextBlock>
                            <Run Text="{Binding Current.Display.FontSize, Mode=OneWay}"/><Run Text=" px"/>
                        </TextBlock>

                        <TextBlock Text="字体颜色" Margin="0,8,0,4"/>
                        <ComboBox SelectedItem="{Binding Current.Display.FontColorPreset}"
                                  ItemsSource="{Binding FontColorPresets}"/>

                        <CheckBox Content="粗体" IsChecked="{Binding Current.Display.FontBold}" Margin="0,8,0,0"/>

                        <TextBlock Text="行间距" Margin="0,8,0,4"/>
                        <Slider Minimum="1.0" Maximum="2.5" TickFrequency="0.1"
                                Value="{Binding Current.Display.LineHeight}" IsSnapToTickEnabled="True"/>
                        <TextBlock>
                            <Run Text="{Binding Current.Display.LineHeight, Mode=OneWay}"/><Run Text=" x"/>
                        </TextBlock>

                        <TextBlock Text="背景颜色" Margin="0,8,0,4"/>
                        <ComboBox x:Name="BackgroundCombo" SelectedItem="{Binding Current.Display.BackgroundPreset}"/>

                        <TextBlock Text="透明度" Margin="0,8,0,4"/>
                        <Slider Minimum="0.2" Maximum="1.0" TickFrequency="0.05"
                                Value="{Binding Current.Display.Opacity}" IsSnapToTickEnabled="True"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 自动阅读 -->
            <TabItem Header="自动阅读">
                <StackPanel Margin="12">
                    <TextBlock Text="自动翻页间隔（秒）" Margin="0,8,0,4"/>
                    <Slider Minimum="1" Maximum="60" TickFrequency="1"
                            Value="{Binding AutoReadIntervalSec}" IsSnapToTickEnabled="True"/>
                    <TextBlock>
                        <Run Text="{Binding AutoReadIntervalSec, Mode=OneWay}"/><Run Text=" 秒"/>
                    </TextBlock>
                </StackPanel>
            </TabItem>

            <!-- 启动 -->
            <TabItem Header="启动">
                <StackPanel Margin="12">
                    <TextBlock Text="启动时" Margin="0,8,0,4"/>
                    <ComboBox SelectedItem="{Binding Current.StartupBehavior}">
                        <ComboBoxItem Content="恢复上次阅读位置"/>
                        <ComboBoxItem Content="打开书架"/>
                    </ComboBox>
                </StackPanel>
            </TabItem>

            <!-- 快捷键 -->
            <TabItem Header="快捷键">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="HotkeyList" Margin="12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                                    <ctrl:HotkeyTextBox Grid.Column="1"
                                                        Hotkey="{Binding Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="取消" Padding="16,6" Margin="6,0" Click="OnCancel"/>
            <Button Content="保存" Padding="16,6" Margin="6,0" Click="OnSave"/>
        </StackPanel>
    </Grid>
</Window>
